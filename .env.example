# DO NOT COMMIT your real .env. Use this as example only.

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/nebula
SPRING_DATASOURCE_USERNAME=nebula
SPRING_DATASOURCE_PASSWORD=nebula

# RabbitMQ
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# JWT secret (use um valor forte em produção)
JWT_SECRET=change-me-secret

# Worker
WORKER_WORK_DIR=/tmp/worker

# Docker (se necessário para docker-in-docker via socket)
# DOCKER_HOST=unix:///var/run/docker.sock
